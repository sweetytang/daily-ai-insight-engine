{
  "name": "daily-ai-insight-engine",
  "version": "1.0.0",
  "description": "AI舆情分析日报系统 MVP",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "node backend/server.js",
    "dev:frontend": "vite --config frontend/pack/vite.config.ts",
    "db:push": "pnpm exec prisma db push",
    "prisma:generate": "pnpm exec prisma generate",
    "db:init": "node backend/scripts/init-db.js",
    "seed": "node backend/scripts/seed.js",
    "setup": "pnpm run prisma:generate && pnpm run db:init && pnpm run seed",
    "build": "vite build --config frontend/pack/vite.config.ts",
    "test": "node --test backend/tests/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-sdk": "^1.8.9",
    "@langchain/openai": "^1.4.4",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "langchain": "^1.3.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "zustand": "^5.0.12"
  }
}